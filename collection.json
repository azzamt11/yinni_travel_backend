{
  "info": {
    "_postman_id": "9cf6ff7d-9d9e-4f2e-a53f-2fb6a9f0e101",
    "name": "Yinni Travel Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Sign Up",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo@example.com\",\n  \"password\": \"secret123\",\n  \"name\": \"Demo User\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/auth/sign-up",
              "host": ["{{base_url}}"],
              "path": ["v1", "auth", "sign-up"]
            }
          }
        },
        {
          "name": "Sign In",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access_token) pm.environment.set('access_token', res.access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo@example.com\",\n  \"password\": \"secret123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/auth/sign-in",
              "host": ["{{base_url}}"],
              "path": ["v1", "auth", "sign-in"]
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/auth/me",
              "host": ["{{base_url}}"],
              "path": ["v1", "auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Booking",
      "item": [
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": {{user_id}},\n  \"hotel_id\": {{hotel_id}},\n  \"booking_date_start\": \"2026-03-01T14:00:00Z\",\n  \"booking_date_end\": \"2026-03-03T11:00:00Z\",\n  \"price\": 220.5,\n  \"name\": \"Weekend Stay\",\n  \"number_of_guests\": 2\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/bookings",
              "host": ["{{base_url}}"],
              "path": ["v1", "bookings"]
            }
          }
        },
        {
          "name": "See Bookings",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/bookings?user_id={{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "bookings"],
              "query": [
                { "key": "user_id", "value": "{{user_id}}" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Hotels",
      "item": [
        {
          "name": "List Hotels",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/hotels?page=1&page_size=10",
              "host": ["{{base_url}}"],
              "path": ["v1", "hotels"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "page_size", "value": "10" }
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://localhost:8200" },
    { "key": "access_token", "value": "" },
    { "key": "user_id", "value": "1" },
    { "key": "hotel_id", "value": "1" }
  ]
}
